# SILICONFLOW_API_KEY: Required for SiliconFlow API calls.
SILICONFLOW_API_KEY="your_siliconflow_api_key_here"
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_MODEL="deepseek-ai/DeepSeek-V3"

# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:3000"

# MySQL settings
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD="your_mysql_password"
DB_NAME="xinyi"

# SMS and WeChat auth
# MOCK_SMS=false: use real Aliyun SMS API
# MOCK_SMS=true: development mode, prints code to server logs
MOCK_SMS="false"
MOCK_WECHAT_AUTH="true"

# Aliyun SMS (required when MOCK_SMS=false)
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""
# Optional:
# ALIYUN_SMS_ENDPOINT="https://dysmsapi.aliyuncs.com/"

# WeChat Open Platform web QR login (when MOCK_WECHAT_AUTH=false)
WECHAT_OPEN_APP_ID=""
WECHAT_OPEN_REDIRECT_URI=""
