# SILICONFLOW_API_KEY: Required for SiliconFlow API calls.
SILICONFLOW_API_KEY="your_siliconflow_api_key_here"
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_MODEL="deepseek-ai/DeepSeek-V3"

# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:3000"

# MySQL settings
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD="your_mysql_password"
DB_NAME="xinyi"

# SMS and WeChat auth (mock by default)
MOCK_SMS="true"
MOCK_WECHAT_AUTH="true"

# WeChat Open Platform web QR login (when MOCK_WECHAT_AUTH=false)
WECHAT_OPEN_APP_ID=""
WECHAT_OPEN_REDIRECT_URI=""
