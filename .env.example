# ---------------------------------------------------------------------------
# SiliconFlow AI API (required)
# ---------------------------------------------------------------------------
SILICONFLOW_API_KEY="your_siliconflow_api_key_here"
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_MODEL="deepseek-ai/DeepSeek-V3"

# ---------------------------------------------------------------------------
# App URL (used for CORS Allow-Origin header)
# ---------------------------------------------------------------------------
APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Server port (optional — defaults to 3001)
# ---------------------------------------------------------------------------
PORT=3001

# ---------------------------------------------------------------------------
# MySQL — Railway deployment (recommended)
# ---------------------------------------------------------------------------
# Option A: single connection-string URL (Railway provides MYSQL_URL or
#           DATABASE_URL automatically when you link a MySQL service).
# MYSQL_URL="mysql://user:password@host:3306/dbname"
# DATABASE_URL="mysql://user:password@host:3306/dbname"

# Option B: individual Railway reference variables.
# In the Railway dashboard, set each variable as a reference to the
# corresponding variable exposed by the MySQL service plugin, e.g.:
#   MYSQLHOST     → ${{MySQL.MYSQLHOST}}
#   MYSQLPORT     → ${{MySQL.MYSQLPORT}}
#   MYSQLUSER     → ${{MySQL.MYSQLUSER}}
#   MYSQLPASSWORD → ${{MySQL.MYSQLPASSWORD}}
#   MYSQLDATABASE → ${{MySQL.MYSQLDATABASE}}
MYSQLHOST="your-mysql-railway-host"
MYSQLPORT="3306"
MYSQLUSER="root"
MYSQLPASSWORD="your_mysql_password"
MYSQLDATABASE="xinyi"

# ---------------------------------------------------------------------------
# MySQL — local development (alternative variable names also supported)
# ---------------------------------------------------------------------------
# DB_HOST="127.0.0.1"
# DB_PORT="3306"
# DB_USER="root"
# DB_PASSWORD="your_mysql_password"
# DB_NAME="xinyi"
